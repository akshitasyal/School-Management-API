  },
  "item": [
    {
      "name": "Add School",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Delhi Public School\",\n  \"address\": \"Lucknow\",\n  \"latitude\": 26.8467,\n  \"longitude\": 80.9462\n}"
        },
        "url": {
          "raw": "http://localhost:5000/api/addSchool",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api", "addSchool"]
        }
      }
    },
    {
      "name": "List Schools",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:5000/api/listSchools?latitude=26.8467&longitude=80.9462",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api", "listSchools"],
          "query": [
            {
              "key": "latitude",
              "value": "26.8467"
            },
            {
              "key": "longitude",
              "value": "80.9462"
            }
          ]
        }
      }
    }
  ]
